#usda 1.0
(
    defaultPrim = "Scene"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Scene"
{
    def Xform "Car"
    {
        def Xform "Wheels"
        {
            def Mesh "Left"
            {
                int[] faceVertexCounts = [3]
                int[] faceVertexIndices = [0, 1, 2]
                point3f[] points = [(0, 0, 0), (1, 0, 0), (0, 1, 0)]
            }
            def Mesh "Right"
            {
                int[] faceVertexCounts = [3]
                int[] faceVertexIndices = [0, 1, 2]
                point3f[] points = [(2, 0, 0), (3, 0, 0), (2, 1, 0)]
            }
        }
        def Mesh "Body"
        {
            int[] faceVertexCounts = [3]
            int[] faceVertexIndices = [0, 1, 2]
            point3f[] points = [(0, 0, 1), (1, 0, 1), (0, 1, 1)]
        }
    }
    def Mesh "Ground"
    {
        int[] faceVertexCounts = [3]
        int[] faceVertexIndices = [0, 1, 2]
        point3f[] points = [(-5, -1, -5), (5, -1, -5), (0, -1, 5)]
    }
}
